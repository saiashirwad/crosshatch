{
  "name": "crosshatch",
  "type": "module",
  "scripts": {
    "prepare": "ts-patch install -s",
    "build": "tsc -b",
    "watch": "tsc -b -w",
    "clean": "node ./konfik/main.ts clean --ignore '**/repos'",
    "deploy:github": "alchemy deploy stacks/github.ts --stage prod --yes --env-file .env --profile crosshatch-env",
    "sync-repos": "node ./konfik/main.ts sync-repos",
    "dev": "turbo run //#watch //#test dev",
    "test": "vitest run"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/expect": "catalog:",
    "@vitest/web-worker": "catalog:",
    "alchemy": "catalog:",
    "effect": "catalog:",
    "fake-indexeddb": "catalog:",
    "happy-dom": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "ts-patch": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  },
  "packageManager": "pnpm@11.5.0"
}
