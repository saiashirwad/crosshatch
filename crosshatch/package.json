{
  "name": "crosshatch",
  "version": "0.0.3",
  "private": false,
  "description": "x402 x Effect",
  "homepage": "https://crosshatch.dev",
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "packages/crosshatch"
  },
  "bin": {
    "crosshatch": "./dist/main.js"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./index.ts",
    "./*": "./*.ts",
    "./Browser": "./Browser/Browser.ts",
    "./Evm": "./Evm/Evm.ts",
    "./Facade": "./Facade/Facade.ts",
    "./Http402": "./Http402/Http402.ts",
    "./KnownAsset": "./KnownAsset/KnownAsset.ts",
    "./Svm": "./Svm/Svm.ts",
    "./internal": "./internal/internal.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./*": "./dist/*/index.js",
      "./Browser": "./dist/Browser/Browser.js",
      "./Evm": "./dist/Evm/Evm.js",
      "./Facade": "./dist/Facade/Facade.js",
      "./Http402": "./dist/Http402/Http402.js",
      "./KnownAsset": "./dist/KnownAsset/KnownAsset.js",
      "./Svm": "./dist/Svm/Svm.js",
      "./internal": "./dist/internal/internal.js",
      "./package.json": "./package.json"
    }
  },
  "peerDependencies": {
    "@crosshatch/widget": "workspace:*",
    "@effect/platform-browser": "catalog:",
    "@standard-schema/spec": "catalog:",
    "effect": "catalog:",
    "liminal": "workspace:*",
    "liminal-util": "workspace:*",
    "ox": "catalog:",
    "viem": "catalog:"
  }
}
