{
  "name": "crosshatch",
  "version": "0.0.12",
  "private": false,
  "description": "Effect x x402",
  "homepage": "https://crosshatch.dev",
  "bugs": {
    "url": "https://github.com/crosshatch/crosshatch/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/crosshatch/crosshatch.git",
    "directory": "packages/crosshatch"
  },
  "bin": {
    "crosshatch": "./dist/Cli/main.js"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./index.ts",
    "./*": "./*.ts",
    "./Browser": "./Browser/Browser.ts",
    "./Crypto": "./Crypto/Crypto.ts",
    "./Eip155": "./Eip155/Eip155.ts",
    "./Extensions": "./Extensions/Extensions.ts",
    "./Facade": "./Browser/Facade/Facade.ts",
    "./FacilitatorApi": "./FacilitatorApi/FacilitatorApi.ts",
    "./Ramp": "./Ramp/Ramp.ts",
    "./Solana": "./Solana/Solana.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./Browser": "./dist/Browser/Browser.js",
      "./Crypto": "./dist/Crypto/Crypto.js",
      "./Eip155": "./dist/Eip155/Eip155.js",
      "./Extensions": "./dist/Extensions/Extensions.js",
      "./Facade": "./dist/Browser/Facade/Facade.js",
      "./FacilitatorApi": "./dist/FacilitatorApi/FacilitatorApi.js",
      "./Ramp": "./dist/Ramp/Ramp.js",
      "./Solana": "./dist/Solana/Solana.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "dev": "node --watch ./Cli/main.ts dev --port 4647 --otel-endpoint http://127.0.0.1:27686"
  },
  "peerDependencies": {
    "@crosshatch/widget": "workspace:*",
    "@effect/platform-browser": "catalog:",
    "@effect/platform-node": "catalog:",
    "@napi-rs/keyring": "catalog:",
    "@scure/bip39": "catalog:",
    "@solana-program/compute-budget": "catalog:",
    "@solana-program/memo": "catalog:",
    "@solana-program/token": "catalog:",
    "@solana/addresses": "catalog:",
    "@solana/kit": "catalog:",
    "@solana/transactions": "catalog:",
    "@standard-schema/spec": "catalog:",
    "effect": "catalog:",
    "liminal": "workspace:*",
    "liminal-util": "workspace:*",
    "ox": "catalog:"
  }
}
