{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["."],
  "references": [
    { "path": "../@crosshatch/caip" },
    { "path": "../@crosshatch/merchant" },
    { "path": "../@crosshatch/x402" },
    { "path": "../crosshatch" },
    { "path": "../liminal/effect-workerd" }
  ]
}
